# PI SDK Python Configuration

# LLM Provider Configuration
# Available models (via LiteLLM):
# - anthropic/claude-sonnet-4-20250514
# - anthropic/claude-3-5-sonnet-20241022
# - openai/gpt-4o
# - openai/gpt-4o-mini
# - google/gemini-2.0-flash-exp
# etc.
MODEL=anthropic/claude-sonnet-4-20250514

# API Key for your LLM provider
# For Anthropic: https://console.anthropic.com/
# For OpenAI: https://platform.openai.com/api-keys
# For AIHubMix: Your API key
API_KEY=your_api_key_here

# Optional: Custom API base URL
# For AIHubMix: https://aihubmix.com/v1
# For other providers: Leave empty to use default
API_BASE=

# Optional: Custom system prompt
# If not set, the default coding agent prompt will be used
# SYSTEM_PROMPT=You are a helpful coding assistant...

# Optional: Working directory for file operations
# Default: Current directory
# CWD=.
